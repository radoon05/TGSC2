# Database
DATABASE_URL=postgres://user:password@localhost:5432/scraper_sync?sslmode=disable

# HTTP Server
HTTP_PORT=8080
LOG_LEVEL=info

# Scraper
SCRAPER_BASE_URL=https://example.com/api/products
SCRAPER_TIMEOUT=30s
SCRAPER_RATE_LIMIT=5
SCRAPER_RETRY_MAX=3
SCRAPER_RETRY_BACKOFF=2s
SCRAPER_PAGE_SIZE=50

# WooCommerce
WOO_BASE_URL=https://yourstore.com/wp-json/wc/v3
WOO_CONSUMER_KEY=ck_your_consumer_key
WOO_CONSUMER_SECRET=cs_your_consumer_secret
WOO_TIMEOUT=30s
WOO_RATE_LIMIT=10
WOO_BATCH_CREATE_SIZE=10
WOO_BATCH_UPDATE_SIZE=25

# Sync Engine
SYNC_WORKER_COUNT=5
SYNC_FETCH_LIMIT=100
SYNC_RETRY_BACKOFF_BASE=30s
SYNC_MAX_RETRIES=3